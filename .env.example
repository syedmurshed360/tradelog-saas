# PostgreSQL connection string.
# Get this from your database provider (Neon / Supabase / Railway) after creating a project.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Used starting Phase 1 (NextAuth) — not needed yet, listed here for reference ---
# NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# NEXTAUTH_URL="http://localhost:3000"

# NextAuth (required from Phase 1)
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
# On Vercel, set NEXTAUTH_URL to your production URL e.g. https://tradelog-saas.vercel.app
