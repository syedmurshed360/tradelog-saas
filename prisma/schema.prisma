generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
  brokers       Broker[]
  forexTrades   ForexTrade[]
  binaryTrades  BinaryTrade[]
  payments      Payment[]
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  price         Float
  durationDays  Int
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startedAt DateTime           @default(now())
  expiresAt DateTime
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan               @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Broker {
  id           String        @id @default(cuid())
  userId       String
  name         String
  type         String
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  forexTrades  ForexTrade[]
  binaryTrades BinaryTrade[]

  @@index([userId])
}

model ForexTrade {
  id         String   @id @default(cuid())
  userId     String
  brokerId   String?
  date       DateTime
  pair       String
  direction  String
  entry      Float
  exit       Float
  lots       Float
  pips       Float
  profitLoss Float
  notes      String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker     Broker?  @relation(fields: [brokerId], references: [id])

  @@index([userId])
}

model BinaryTrade {
  id            String   @id @default(cuid())
  userId        String
  brokerId      String?
  date          DateTime
  stake         Float
  payoutPercent Float
  result        String
  profitLoss    Float
  notes         String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker        Broker?  @relation(fields: [brokerId], references: [id])

  @@index([userId])
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  amount        Float
  gateway       String
  status        PaymentStatus @default(PENDING)
  transactionId String?
  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
